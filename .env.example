# aring 환경 변수 예시
# 실제 값은 .env.local에 작성 (커밋 금지)

# 공공데이터포털 LOST112 분실물 통합 API
# https://www.data.go.kr/data/15063505/openapi.do
# 발급받은 서비스키(URL 인코딩 전 원본)를 입력하세요.
# 비어 있으면 화면은 mock 데이터로 동작합니다.
LOST112_API_KEY=
LOST112_API_BASE=http://apis.data.go.kr/1320000/LosfundInfoInqireService

# Google Analytics 4 — 유입 분석용
# GA4 콘솔 → 관리 → 데이터 스트림 → 웹 → "측정 ID" 복사 (G-로 시작)
# 클라이언트 노출 변수이므로 NEXT_PUBLIC_ 접두사 필수
NEXT_PUBLIC_GA_ID=
